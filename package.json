{
  "name": "cev-dealer-portal",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "predev": "powershell -ExecutionPolicy Bypass -File scripts/kill-ports.ps1",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "kill-ports": "powershell -ExecutionPolicy Bypass -File scripts/kill-ports.ps1",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "build:railway:api": "npm run db:generate && npm run build --workspace=api",
    "start:railway:api": "npm run db:deploy && npm run start:prod --workspace=api",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:verify": "node scripts/verify-migrations.js",
    "db:migrate:all": "powershell -ExecutionPolicy Bypass -File scripts/db-migrate-all.ps1",
    "db:verify:prod": "node scripts/verify-production-api.js",
    "db:push": "prisma db push",
    "db:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-db.ps1",
    "db:seed": "prisma db seed",
    "db:deploy": "prisma migrate deploy && npm run db:seed",
    "db:studio": "prisma studio",
    "icons:sync": "node scripts/sync-icons.js"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "concurrently": "^9.1.2",
    "prisma": "^6.8.2",
    "sharp": "^0.35.2",
    "tsx": "^4.19.4"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
