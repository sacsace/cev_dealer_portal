DATABASE_URL="postgresql://cev:cev_password@localhost:5432/cev_dealer_portal?schema=public"
DIRECT_DATABASE_URL="postgresql://cev:cev_password@localhost:5432/cev_dealer_portal?schema=public"

# Optional: shadow DB for `prisma migrate dev` when DB user cannot CREATE DATABASE
# SHADOW_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/cev_shadow?schema=public"

# 로컬 PostgreSQL 사용 시: 아래 중 하나를 선택하세요
# 1) 관리자 비밀번호로 DB/유저 자동 생성:
#    $env:PGPASSWORD='postgres관리자비밀번호'; npm run db:setup
# 2) 본인 계정으로 직접 연결 (예시):
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/cev_dealer_portal?schema=public"

JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

API_PORT=3001
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Railway deploy ---
# 1) web service → Config-as-code: railway.web.toml (no leading slash!)
#    Variables (set BEFORE first deploy; API_URL can be changed without rebuild):
#      API_URL=https://<api-domain>/api   ← /api suffix required (auto-appended if missing)
#      NEXT_PUBLIC_API_URL=https://<api-domain>/api
#      NEXT_PUBLIC_SITE_URL=https://www.mycev.in
#    DELETE if present: NPM_CONFIG_OMIT, NPM_CONFIG_PRODUCTION
#
# 2) api service → Config-as-code: railway.api.toml (no leading slash!)
#    Variables:
#      DATABASE_URL=${{Postgres.DATABASE_URL}}   ← Reference from Postgres service
#      DIRECT_DATABASE_URL=${{Postgres.DATABASE_UNPOOLED_URL}}  ← Required if PgBouncer is on
#      (If unpooled var is missing, entrypoint falls back to DATABASE_URL)
#      NODE_ENV=production
#      JWT_SECRET=<32+ char random>
#      JWT_REFRESH_SECRET=<different random>
#      FRONTEND_URL=https://<web-domain>
#    Tables are NOT auto-created by Railway Postgres — api start runs migrate + seed.
#    DELETE if present: NPM_CONFIG_OMIT, NPM_CONFIG_PRODUCTION
#
# 3) Redeploy both with "Clear build cache"
#    api start runs: migrate deploy + seed (upsert, safe to re-run)

UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

