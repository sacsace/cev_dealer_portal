DATABASE_URL="postgresql://cev:cev_password@localhost:5432/cev_dealer_portal?schema=public"

# Optional: shadow DB for `prisma migrate dev` when DB user cannot CREATE DATABASE
# SHADOW_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/cev_shadow?schema=public"

# 로컬 PostgreSQL 사용 시: 아래 중 하나를 선택하세요
# 1) 관리자 비밀번호로 DB/유저 자동 생성:
#    $env:PGPASSWORD='postgres관리자비밀번호'; npm run db:setup
# 2) 본인 계정으로 직접 연결 (예시):
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/cev_dealer_portal?schema=public"

JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

API_PORT=3001
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Railway (production) ---
# api service only:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   NODE_ENV=production
#   JWT_SECRET=<32+ char random>
#   JWT_REFRESH_SECRET=<different random>
#   FRONTEND_URL=https://<your-web-service>.up.railway.app
# web service only (set BEFORE build):
#   NEXT_PUBLIC_API_URL=https://<your-api-service>.up.railway.app/api
#   NEXT_PUBLIC_SITE_URL=https://<your-web-service>.up.railway.app
#   NPM_CONFIG_PRODUCTION=false
#   NPM_CONFIG_INCLUDE=optional
# Config files: railway.toml (web), railway.api.toml (api)
# Docker alternative: Dockerfile.web / Dockerfile.api

UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
